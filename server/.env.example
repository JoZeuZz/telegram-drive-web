# Environment configuration for telegram-drive-server
# Copy to .env and adjust values

# ─── Server ─────────────────────────────────────────────
HOST=127.0.0.1
PORT=8080

# ─── Frontend (CORS origin) ────────────────────────────
FRONTEND_PORT=3000

# ─── Paths ──────────────────────────────────────────────
DATA_DIR=./data
CACHE_DIR=./data/cache

# ─── Security ──────────────────────────────────────────
# Random 32+ char secret used to sign session cookies.
# Generate with: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_random_hex_string

# Admin password for /api/app-auth/login.
# On first start the server hashes and stores it in DATA_DIR/admin.json.
# After that this var is only read if the hash file is missing.
ADMIN_PASSWORD=changeme

# ─── Telegram ──────────────────────────────────────────
# Obtain from https://my.telegram.org/apps
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=

# ─── Logging ───────────────────────────────────────────
RUST_LOG=info
