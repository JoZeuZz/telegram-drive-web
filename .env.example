# Global environment contract for telegram-drive-web
# Single source of truth for local dev, Coolify UI, and systemd deployments.
#
# Usage examples:
# - Local backend: cp .env.example server/.env
# - Local Coolify compose validation: cp .env.example .env.coolify
# - Coolify production: set real values in Coolify UI (do not commit secrets)

# Server
HOST=127.0.0.1
PORT=8080

# Frontend origin / CORS
# In production set to your public URL, e.g. https://drive.example.com
FRONTEND_PORT=3000
CORS_ALLOWED_ORIGIN=http://localhost:3000

# Paths
# For local dev these are relative to server/ when running cargo there.
DATA_DIR=./data
CACHE_DIR=./data/cache

# Security
# Generate with: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_random_hex_string
COOKIE_SECURE=false
SESSION_TTL_HOURS=8
ADMIN_PASSWORD=changeme

# Telegram credentials (from https://my.telegram.org/apps)
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=replace-with-api-hash

# Logging
RUST_LOG=info
LOG_FORMAT=json
