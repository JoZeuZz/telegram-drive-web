# Cloudflared tunnel config template for split deployment.
# Use placeholders only; never commit real tunnel IDs, tokens, private hosts, or credentials.

# UUID returned by: cloudflared tunnel create <name>
tunnel: replace-with-tunnel-uuid

# Credentials JSON generated by cloudflared
credentials-file: /etc/cloudflared/replace-with-tunnel-uuid.json

ingress:
  - hostname: teldrive.example.com
    # URL reachable from cloudflared node to the Coolify proxy entrypoint.
    # Replace with your internal DNS name or private endpoint.
    service: http://coolify-proxy.example.internal
    originRequest:
      # Must match hostname for host-based routing in Coolify/Traefik.
      httpHostHeader: teldrive.example.com
      connectTimeout: 30s
      noTLSVerify: false

  # Catch-all fallback
  - service: http_status:404
