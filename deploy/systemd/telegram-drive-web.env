# Environment variables for telegram-drive-web systemd service
# Copy to /opt/telegram-drive-web/.env and edit.

HOST=127.0.0.1
PORT=8080
FRONTEND_PORT=80
DATA_DIR=/opt/telegram-drive-web/data
CACHE_DIR=/opt/telegram-drive-web/data/cache
RUST_LOG=info

# Structured JSON logging (recommended for production / journald)
LOG_FORMAT=json

# REQUIRED — generate with: openssl rand -hex 32
# SESSION_SECRET=

# REQUIRED — change from the default
# ADMIN_PASSWORD=

# REQUIRED — Telegram API credentials from https://my.telegram.org
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
